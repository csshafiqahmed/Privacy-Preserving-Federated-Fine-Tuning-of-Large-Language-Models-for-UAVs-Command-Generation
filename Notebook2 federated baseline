"Total parameters:     620,111,872\nTrainable (LoRA):     4,505,600\nTrainable %:          0.73%\nModel loaded.\n","output_type":"stream"}],"execution_count":6},{"cell_type":"code","source":"# =============================================================================\n# PHASE 7: FEDERATED TRAINING LOOP\n# =============================================================================\n\ndef run_federated_experiment(model, tokenizer, client_datasets, val_raw,\n                             test_raw, alpha, num_rounds, local_epochs):\n    \"\"\"\n    Run one complete federated learning experiment with FedAvg.\n    Returns metrics history per round.\n    \"\"\"\n    \n    print(f\"\\n{'='*60}\")\n    print(f\"FEDERATED EXPERIMENT: alpha={alpha}\")\n    print(f\"{'='*60}\")\n    print(f\"Clients: {len(client_datasets)}\")\n    print(f\"Rounds: {num_rounds}\")\n    print(f\"Local epochs: {local_epochs}\")\n    \n    # Save initial global LoRA weights\n    global_state = get_lora_state_dict(model)\n    \n    # Track metrics per round\n    history = {\n        \"rounds\": [],\n        \"train_losses\": [],\n        \"eval_metrics\": [],\n    }\n    \n    experiment_start = time.time()\n    \n    for round_num in range(1, num_rounds + 1):\n        round_start = time.time()\n        \n        client_states = []\n        client_sizes = []\n        client_losses = []\n        \n        # ---- Local Training on Each Client ----\n        for c_idx, c_data in enumerate(client_datasets):\n            \n            # Reset model to global weights\n            set_lora_state_dict(model, global_state)\n            \n            # Prepare client's local dataset\n            c_formatted = [{\"text\": format_sample(s)} for s in c_data]\n            c_dataset = Dataset.from_list(c_formatted)\n            \n            # Local training\n            local_args = TrainingArguments(\n                output_dir=os.path.join(OUTPUT_DIR, f\"tmp_client_{c_idx}\"),\n                num_train_epochs=local_epochs,\n                per_device_train_batch_size=LOCAL_BATCH_SIZE,\n                gradient_accumulation_steps=LOCAL_GRADIENT_ACCUMULATION,\n                learning_rate=LOCAL_LEARNING_RATE,\n                warmup_steps=10,\n                fp16=False,\n                bf16=False,\n                max_grad_norm=0,\n                optim=\"adamw_torch\",\n                logging_steps=9999,          # suppress logging\n                save_strategy=\"no\",\n                report_to=\"none\",\n                seed=SEED + round_num + c_idx,\n                dataloader_num_workers=0,\n                remove_unused_columns=True,\n            )\n            \n            local_trainer = SFTTrainer(\n                model=model,\n                args=local_args,\n                train_dataset=c_dataset,\n                processing_class=tokenizer,\n            )\n            \n            local_result = local_trainer.train()\n            client_losses.append(local_result.training_loss)\n            \n            # Extract trained LoRA weights\n            client_state = get_lora_state_dict(model)\n            client_states.append(client_state)\n            client_sizes.append(len(c_data))\n            \n            # Clean up trainer to free memory\n            # Clean up trainer to free memory\n            del local_trainer, local_args, c_dataset, c_formatted\n            gc.collect()\n            torch.cuda.empty_cache()\n        \n        # ---- FedAvg Aggregation ----\n        global_state = fedavg_aggregate(client_states, client_sizes)\n        \n        # Load aggregated weights into model\n        set_lora_state_dict(model, global_state)\n        \n        round_time = time.time() - round_start\n        avg_loss = np.mean(client_losses)\n        \n        history[\"rounds\"].append(round_num)\n        history[\"train_losses\"].append(round(float(avg_loss), 4))\n        \n        # ---- Periodic Evaluation ----\n        if round_num % EVAL_EVERY_N_ROUNDS == 0 or round_num == num_rounds:\n            print(f\"\\n  Round {round_num}/{num_rounds} | \"\n                  f\"Avg Loss: {avg_loss:.4f} | Time: {round_time:.0f}s\")\n            print(f\"  Evaluating...\", end=\" \", flush=True)\n            \n            metrics = evaluate_model(model, tokenizer, test_raw, NUM_EVAL_SAMPLES)\n            history[\"eval_metrics\"].append({\n                \"round\": round_num,\n                **metrics\n            })\n            \n            print(f\"BLEU={metrics['bleu']:.4f} | \"\n                  f\"JSON={metrics['json_validity']}% | \"\n                  f\"CmdType={metrics['cmd_type_acc']}% | \"\n                  f\"Action={metrics['action_acc']}%\")\n        else:\n            print(f\"  Round {round_num}/{num_rounds} | \"\n                  f\"Avg Loss: {avg_loss:.4f} | Time: {round_time:.0f}s\")\n    \n    total_time = time.time() - experiment_start\n    print(f\"\\n  Experiment completed in {total_time/60:.1f} minutes\")\n    \n    history[\"total_time_minutes\"] = round(total_time / 60, 1)\n    \n    return history\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-10T12:23:29.969567Z","iopub.execute_input":"2026-03-10T12:23:29.970261Z","iopub.status.idle":"2026-03-10T12:23:29.981826Z","shell.execute_reply.started":"2026-03-10T12:23:29.970227Z","shell.execute_reply":"2026-03-10T12:23:29.981123Z"}},"outputs":[],"execution_count":7},{"cell_type":"code","source":"# =============================================================================\n# PHASE 8: RUN ALL EXPERIMENTS\n# =============================================================================\n\nprint(\"\\n\" + \"=\" * 60)\nprint(\"RUNNING FEDERATED EXPERIMENTS\")\nprint(\"=\" * 60)\nprint(f\"Start time: {datetime.now().strftime('%H:%M:%S')}\")\n\nall_results = {}\nimport gc\nos.environ[\"TOKENIZERS_PARALLELISM\"] = \"false\"\nfor alpha in ALPHA_VALUES:\n    \n    # Get pre-computed client split for this alpha\n    client_datasets = all_splits[alpha]\n    \n    # Reset model to fresh LoRA weights before each experiment\n    # Re-initialize LoRA from scratch\n    for name, param in model.named_parameters():\n        if \"lora_A\" in name:\n            torch.nn.init.kaiming_uniform_(param, a=np.sqrt(5))\n        elif \"lora_B\" in name:\n            torch.nn.init.zeros_(param)\n    \n    history = run_federated_experiment(\n        model=model,\n        tokenizer=tokenizer,\n        client_datasets=client_datasets,\n        val_raw=val_raw,\n        test_raw=test_raw,\n        alpha=alpha,\n        num_rounds=NUM_ROUNDS,\n        local_epochs=LOCAL_EPOCHS,\n    )\n    \n    all_results[str(alpha)] = history\n    \n    # Save intermediate results after each alpha experiment\n    results_path = os.path.join(OUTPUT_DIR, \"fedavg_results.json\")\n    with open(results_path, 'w') as f:\n        json.dump(all_results, f, indent=2)\n    print(f\"\\n  Results saved to {results_path}\")\n\nprint(f\"\\nAll experiments completed at {datetime.now().strftime('%H:%M:%S')}\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-10T12:23:29.982821Z","iopub.execute_input":"2026-03-10T12:23:29.983144Z","iopub.status.idle":"2026-03-10T19:52:27.265362Z","shell.execute_reply.started":"2026-03-10T12:23:29.983111Z","shell.execute_reply":"2026-03-10T19:52:27.264705Z"}},"outputs":[{"name":"stdout","text":"\n============================================================\nRUNNING FEDERATED EXPERIMENTS\n============================================================\nStart time: 12:23:29\n\n============================================================\nFEDERATED EXPERIMENT: alpha=1.0\n============================================================\nClients: 5\nRounds: 15\nLocal epochs: 1\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"Adding EOS to train dataset:   0%|          | 0/2230 [00:00<?, ? examples/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"vers