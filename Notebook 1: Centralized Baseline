    \n    return formatted\n\n\n# Load data\ndata_path = find_dataset_path()\nprint(f\"\\nDataset found at: {data_path}\")\n\ntrain_raw = load_json(os.path.join(data_path, \"train.json\"))\nval_raw = load_json(os.path.join(data_path, \"val.json\"))\ntest_raw = load_json(os.path.join(data_path, \"test.json\"))\n\nprint(f\"Train: {len(train_raw)} samples\")\nprint(f\"Val:   {len(val_raw)} samples\")\nprint(f\"Test:  {len(test_raw)} samples\")\n\n# Show distribution\ntype_counts = Counter(s[\"output\"][\"command_type\"] for s in train_raw)\nprint(f\"\\nTraining set distribution:\")\nfor ct, count in type_counts.most_common():\n    print(f\"  {ct}: {count} ({count/len(train_raw)*100:.1f}%)\")\n\n# Format for training\ntrain_formatted = [{\"text\": format_sample(s)} for s in train_raw]\nval_formatted = [{\"text\": format_sample(s)} for s in val_raw]\n\ntrain_dataset = Dataset.from_list(train_formatted)\nval_dataset = Dataset.from_list(val_formatted)\n\n# Show one example\nprint(f\"\\n--- Example Formatted Sample ---\")\nprint(train_formatted[0][\"text\"][:500])\nprint(\"...\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-09T23:05:05.700517Z","iopub.execute_input":"2026-03-09T23:05:05.701078Z","iopub.status.idle":"2026-03-09T23:05:06.235560Z","shell.execute_reply.started":"2026-03-09T23:05:05.701052Z","shell.execute_reply":"2026-03-09T23:05:06.234899Z"}},"outputs":[{"name":"stdout","text":"\nDataset found at: /kaggle/input/datasets/csshafiqahmed/uav-llm-command-dataset/final_dataset\nTrain: 12033 samples\nVal:   1203 samples\nTest:  1210 samples\n\nTraining set distribution:\n  navigation: 3908 (32.5%)\n  surveillance: 2639 (21.9%)\n  inspection: 1758 (14.6%)\n  status: 1282 (10.7%)\n  formation: 1161 (9.6%)\n  emergency: 1103 (9.2%)\n  compound: 182 (1.5%)\n\n--- Example Formatted Sample ---\n<|system|>\nYou are a UAV command interpreter. Convert the natural language command into a structured JSON command for drone execution.</s>\n<|user|>\nHea